{
  "name": "@cogni/operator-doltgres-schema",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./work-items": {
      "types": "./dist/work-items.d.ts",
      "import": "./dist/work-items.js",
      "default": "./dist/work-items.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge.d.ts",
      "import": "./dist/knowledge.js",
      "default": "./dist/knowledge.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); for(const f of ['dist/index.js','dist/work-items.js','dist/knowledge.js']){if(!fs.existsSync(f)){console.error('ERROR: '+f+' missing'); process.exit(1)}}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cogni/knowledge-base": "workspace:*",
    "drizzle-orm": "^0.44.7"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
