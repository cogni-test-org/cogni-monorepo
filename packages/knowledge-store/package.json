{
  "name": "@cogni/knowledge-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contribution-schemas": {
      "types": "./dist/domain/contribution-schemas.d.ts",
      "import": "./dist/domain/contribution-schemas.js",
      "default": "./dist/domain/contribution-schemas.js"
    },
    "./adapters/doltgres": {
      "types": "./dist/adapters/doltgres/index.d.ts",
      "import": "./dist/adapters/doltgres/index.js",
      "default": "./dist/adapters/doltgres/index.js"
    },
    "./adapters/fake": {
      "types": "./dist/adapters/fake/index.d.ts",
      "import": "./dist/adapters/fake/index.js",
      "default": "./dist/adapters/fake/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); for(const f of ['dist/index.js','dist/domain/contribution-schemas.js']){if(!fs.existsSync(f)){console.error('ERROR: '+f+' missing'); process.exit(1)}}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@cogni/ai-tools": "workspace:*",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
