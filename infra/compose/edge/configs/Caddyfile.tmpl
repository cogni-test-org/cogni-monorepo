{
  log {
    level INFO
    format json
    output file /data/logs/caddy/caddy.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# Redirect www to non-www (canonical domain)
www.{$DOMAIN} {
  redir https://{$DOMAIN}{uri} permanent
}

# ── Operator (primary domain) → k3s NodePort 30000 ───────────────────────
{$DOMAIN} {
  encode zstd gzip

  @public path /api/v1/public/*
  handle @public {
    reverse_proxy {$OPERATOR_UPSTREAM:app:3000} {
      header_up X-Real-IP {remote_host}
      transport http {
        response_header_timeout 10s
      }
    }
  }

  reverse_proxy {$OPERATOR_UPSTREAM:app:3000}

  log {
    format json
    output file /data/logs/caddy/access.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# ── Resy node → k3s NodePort 30300 ───────────────────────────────────────
{$RESY_DOMAIN} {
  encode zstd gzip

  @public path /api/v1/public/*
  handle @public {
    reverse_proxy {$RESY_UPSTREAM:resy:3300} {
      header_up X-Real-IP {remote_host}
      transport http {
        response_header_timeout 10s
      }
    }
  }

  reverse_proxy {$RESY_UPSTREAM:resy:3300}

  log {
    format json
    output file /data/logs/caddy/access-resy.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# ── node-template node → k3s NodePort 30200 ──────────────────────────────
# task.5078 — first-class node-template deployment. Catalog-driven Caddyfile
# (the spec.repo-sync-contract MULTI_NODE_OUT_OF_BOX invariant) is a separate
# refactor; this entry is the same single-node-hardcoded pattern as resy.
{$NODE_TEMPLATE_DOMAIN} {
  encode zstd gzip

  @public path /api/v1/public/*
  handle @public {
    reverse_proxy {$NODE_TEMPLATE_UPSTREAM:node-template:3200} {
      header_up X-Real-IP {remote_host}
      transport http {
        response_header_timeout 10s
      }
    }
  }

  reverse_proxy {$NODE_TEMPLATE_UPSTREAM:node-template:3200}

  log {
    format json
    output file /data/logs/caddy/access-node-template.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}
